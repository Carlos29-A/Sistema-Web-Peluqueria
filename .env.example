# ============================================
# Configuración del Proyecto — GlamStudio
# ============================================
# Copia este archivo como .env y completa los valores.
# Nunca commitees el archivo .env real al repositorio.
# ============================================

# ─── Docker (Base de Datos Local) ─────────────────
# Variables para docker-compose.yml
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=peluqueria_db

# ─── Base de Datos ──────────────────────────────
# URL de conexión a PostgreSQL.
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:postgres@localhost:5437/peluqueria_db"

# ─── Autenticación ──────────────────────────────
# Secreto para firmar los tokens JWT de NextAuth.js.
# Generá uno seguro con: openssl rand -base64 32
AUTH_SECRET="cambiar_por_un_secreto_seguro_en_produccion"

# ─── Cloudinary (Imágenes) ──────────────────────
# Cloud name de tu cuenta de Cloudinary (visible en el Dashboard).
# Registro gratuito en: https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu_cloud_name"

# Upload preset para subida de imágenes desde el cliente.
# Debe crearse en Cloudinary > Settings > Upload > Upload presets
# Configuración: Modo "Unsigned", permitir cualquier tipo de archivo.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="tu_upload_preset"
